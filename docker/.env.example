# ============================================================
# DailyRadar 环境变量配置模板
# 复制本文件为 .env 并填写真实值：
#   cp docker/.env.example docker/.env
# .env 已被 .gitignore 忽略，不会被提交到版本控制。
# ============================================================

# ── AI 配置（必填）──────────────────────────────────────────
# 任意 OpenAI 兼容接口均可，包括中转服务
AI_API_KEY=
# 模型名称，格式：provider/model_name
# 常见示例：
#   openai/gpt-4o
#   anthropic/claude-sonnet-4-6
#   deepseek/deepseek-chat
#   gemini/gemini-2.5-flash
#   openai/gemini-3.1-pro-preview  （通过中转使用 Gemini）
AI_MODEL=
# 自定义 API 端点（使用官方接口时留空；使用中转/本地服务时填写）
AI_API_BASE=

# ── 邮件配置（必填）─────────────────────────────────────────
# 发件人邮箱
EMAIL_FROM=
# SMTP 授权码（注意：QQ/163 邮箱需使用「授权码」而非登录密码）
EMAIL_PASSWORD=
# 收件人列表，格式：姓名:邮箱地址，多人用英文逗号分隔（姓名可省略，省略则退化为旧格式）
# 示例：张三:zhangsan@example.com,李四:lisi@example.com
# 或旧格式：zhangsan@example.com,lisi@example.com
EMAIL_TO=
# SMTP 服务器
EMAIL_SMTP_SERVER=smtp.qq.com
# SMTP 端口（QQ 邮箱 SSL: 465，TLS: 587）
EMAIL_SMTP_PORT=465
# 开场句启用名单（逗号分隔姓名；默认只启用 yy）
EMAIL_OPENING_AI_NAMES=yy
# 手写开场句（手写优先，没写才 AI）
EMAIL_OPENING_ME=
EMAIL_OPENING_YY=

# ── 信息源 API Keys（可选）──────────────────────────────────
# GitHub Personal Access Token
# 不填：每小时限 60 次 API 请求（通常够用）
# 获取：https://github.com/settings/tokens（无需勾选任何权限）
GITHUB_TOKEN=

# YouTube Data API v3 Key
# 不填：跳过 YouTube 采集
# 获取：https://console.cloud.google.com → 启用 YouTube Data API v3
YOUTUBE_API_KEY=

# ── 飞书群机器人 Webhook（可选）─────────────────────────────
# 在飞书群 → 设置 → 机器人 → 添加自定义机器人 → 复制 Webhook 地址
FEISHU_WEBHOOK_URL=

# ── 企业微信群机器人 Webhook（可选）─────────────────────────
# 在企业微信群 → 右键 → 添加群机器人 → 复制 Webhook 地址
WEWORK_WEBHOOK_URL=
# 消息类型：markdown（富文本）或 text（纯文本）
WEWORK_MSG_TYPE=markdown

# ── 文件输出渠道（无需环境变量）──────────────────────────────
# 通过 config.yaml 的 notifications.file 控制，输出到 data/outputs/

# ── 运行模式（通常无需修改）─────────────────────────────────
# cron：持续运行，按 config.yaml 中的 cron 时间自动触发
# once：单次执行后退出（适合手动触发或调试）
RUN_MODE=cron
# true：容器启动时立即执行一次（适合首次部署验证）
IMMEDIATE_RUN=true
# 指定单次执行的调度名称（RUN_MODE=once 时生效，空则使用第一个 schedule）
SCHEDULE_NAME=
